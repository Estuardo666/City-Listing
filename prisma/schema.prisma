generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DATABASE_URL_UNPOOLED")
}

model NotificationPreference {
  id        String   @id @default(cuid())
  userId    String   @unique
  enabled   Boolean  @default(true)
  hoursAhead Int     @default(48)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model EventNotification {
  id        String   @id @default(cuid())
  userId    String
  eventId   String
  createdAt DateTime @default(now())

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@unique([userId, eventId])
  @@index([userId])
  @@index([eventId])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  password      String?
  role          String    @default("USER")
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Gamificación
  reputationScore  Int      @default(0)
  reviewerLevel    Int      @default(1)
  totalReviews     Int      @default(0)
  totalCheckIns    Int      @default(0)
  totalPhotos      Int      @default(0)
  totalHelpfulVotes Int     @default(0)

  accounts    Account[]
  sessions    Session[]
  events      Event[]
  venues      Venue[]
  posts       Post[]
  notificationPreference NotificationPreference?
  eventNotifications     EventNotification[]
  favorites   Favorite[]
  comments    Comment[]
  reviews     Review[]
  venueClaims VenueClaim[]
  reservations Reservation[]
  routes      Route[]
  questions   Question[]
  checkIns    CheckIn[]
  collections Collection[]
  pushSubscriptions PushSubscription[]
  osmImports  OsmImport[]
  googleImportJobs GoogleImportJob[]
  badges      UserBadge[]
  
  sentMessages      Message[]    @relation("SentMessages")
  receivedMessages  Message[]    @relation("ReceivedMessages")
  quickReplies      QuickReply[]
  blockedUsers      BlockedUser[] @relation("BlockedUsers")
  blockedBy         BlockedUser[] @relation("Blockers")
}

model UserBadge {
  id          String   @id @default(cuid())
  userId      String
  badgeType   String
  name        String
  description String
  icon        String?
  earnedAt    DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@unique([userId, badgeType])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Category {
  id             String   @id @default(cuid())
  name           String
  slug           String   @unique
  description    String?
  seoTitle       String?
  seoDescription String?
  introText      String?
  icon           String?
  color          String?
  type           String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  subcategories      Subcategory[]
  venueCategories    VenueCategory[]
  eventCategories    EventCategory[]
  posts              Post[]

  @@unique([name, type])
}

model Subcategory {
  id             String   @id @default(cuid())
  name           String
  slug           String   @unique
  description    String?
  icon           String?
  color          String?
  categoryId     String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  category           Category            @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  venueSubcategories VenueSubcategory[]
  eventSubcategories EventSubcategory[]

  @@unique([categoryId, name])
  @@index([categoryId])
}

model GooglePlaceTypeMapping {
  id               String   @id @default(cuid())
  googleType       String   @unique
  schemaOrgType    String?
  categorySlugs    String[]
  subcategorySlugs String[]
  confidence       Int      @default(100)
  approved         Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([googleType])
}

model VenueCategory {
  venueId    String
  categoryId String
  createdAt  DateTime @default(now())

  venue    Venue    @relation(fields: [venueId], references: [id], onDelete: Cascade)
  category Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@id([venueId, categoryId])
  @@index([categoryId])
}

model VenueSubcategory {
  venueId       String
  subcategoryId String
  createdAt     DateTime @default(now())

  venue       Venue       @relation(fields: [venueId], references: [id], onDelete: Cascade)
  subcategory Subcategory @relation(fields: [subcategoryId], references: [id], onDelete: Cascade)

  @@id([venueId, subcategoryId])
  @@index([subcategoryId])
}

model EventCategory {
  eventId    String
  categoryId String
  createdAt  DateTime @default(now())

  event    Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  category Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@id([eventId, categoryId])
  @@index([categoryId])
}

model EventSubcategory {
  eventId       String
  subcategoryId String
  createdAt     DateTime @default(now())

  event       Event       @relation(fields: [eventId], references: [id], onDelete: Cascade)
  subcategory Subcategory @relation(fields: [subcategoryId], references: [id], onDelete: Cascade)

  @@id([eventId, subcategoryId])
  @@index([subcategoryId])
}

model Event {
  id             String      @id @default(cuid())
  title          String
  slug           String      @unique
  description    String
  content        String?
  image          String?
  startDate      DateTime
  endDate        DateTime?
  price          Float?
  location       String
  lat            Float?
  lng            Float?
  address        String?
  status         String      @default("PENDING")
  featured       Boolean     @default(false)
  isRecurring    Boolean     @default(false)
  parentEventId  String?
  avgRating      Float?
  reviewCount    Int         @default(0)
  viewCount      Int         @default(0)
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  venueId    String?
  venue      Venue?   @relation(fields: [venueId], references: [id], onDelete: SetNull)
  eventNotifications EventNotification[]
  favorites   Favorite[]
  comments    Comment[]
  media       Media[]
  reviews     Review[]
  recurrenceRule RecurrenceRule?
  reservations   Reservation[]
  collections    CollectionItem[]
  questions      Question[]
  eventCategories    EventCategory[]
  eventSubcategories EventSubcategory[]

  @@index([status])
  @@index([startDate])
  @@index([venueId])
  @@index([viewCount])
}

model Venue {
  id            String      @id @default(cuid())
  name          String
  slug          String      @unique
  description   String
  content       String?
  image         String?
  logo          String?
  coverImage    String?
  phone         String?
  email         String?
  website       String?
  location      String
  lat           Float?
  lng           Float?
  address       String?
  priceRange    String?
  status        String      @default("PENDING")
  isActive      Boolean     @default(true)
  featured      Boolean     @default(false)
  claimed       Boolean     @default(false)
  claimedBy     String?
  verified      Boolean     @default(false)
  badge         String?
  avgRating     Float?
  reviewCount   Int         @default(0)
  viewCount     Int         @default(0)
  googlePlaceId String?     @unique
  osmId         String?     @unique
  sourceLastSync DateTime?
  hoursLastSync  DateTime?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  events     Event[]
  favorites  Favorite[]
  comments   Comment[]
  media      Media[]
  reviews    Review[]
  operatingHours OperatingHours?
  specialHours   SpecialHours[]
  promotions     Promotion[]
  reservations   Reservation[]
  reservationSettings ReservationSettings?
  venueClaims    VenueClaim[]
  routeStops     RouteStop[]
  questions      Question[]
  checkIns       CheckIn[]
  menuCategories MenuCategory[]
  products       Product[]
  collections    CollectionItem[]
  businessHours  VenueBusinessHours[]
  services       VenueService[]
  venueCategories    VenueCategory[]
  venueSubcategories VenueSubcategory[]
  
  parentId      String?
  parent        Venue?    @relation("VenueBranches", fields: [parentId], references: [id], onDelete: SetNull)
  branches      Venue[]   @relation("VenueBranches")
  
  messages      Message[]
  quickReplies  QuickReply[]
  blockedUsers  BlockedUser[]
  branchReviews Review[]  @relation("BranchReviews")

  @@index([status])
  @@index([isActive])
  @@index([googlePlaceId])
  @@index([osmId])
  @@index([avgRating])
  @@index([viewCount])
  @@index([parentId])
}

model Post {
  id          String      @id @default(cuid())
  title       String
  slug        String      @unique
  excerpt     String?
  content     String
  image       String?
  status      String      @default("PENDING")
  featured    Boolean     @default(false)
  viewCount   Int         @default(0)
  publishedAt DateTime?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  categoryId String
  category   Category @relation(fields: [categoryId], references: [id])

  favorites  Favorite[]
  comments   Comment[]
  tags       PostTag[]
  media      Media[]
  collections CollectionItem[]

  @@index([status])
  @@index([publishedAt])
  @@index([categoryId])
}

model Tag {
  id        String    @id @default(cuid())
  name      String    @unique
  slug      String    @unique
  createdAt DateTime  @default(now())

  posts     PostTag[]

  @@index([slug])
}

model PostTag {
  postId String
  tagId  String

  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)
  tag  Tag  @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([postId, tagId])
  @@index([tagId])
}

model Favorite {
  id        String   @id @default(cuid())
  userId    String
  eventId   String?
  venueId   String?
  postId    String?
  routeId   String?
  createdAt DateTime @default(now())

  user  User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  event Event? @relation(fields: [eventId], references: [id], onDelete: Cascade)
  venue Venue? @relation(fields: [venueId], references: [id], onDelete: Cascade)
  post  Post?  @relation(fields: [postId], references: [id], onDelete: Cascade)
  route Route? @relation(fields: [routeId], references: [id], onDelete: Cascade)

  @@unique([userId, eventId])
  @@unique([userId, venueId])
  @@unique([userId, postId])
  @@unique([userId, routeId])
  @@index([userId])
}

model Comment {
  id        String   @id @default(cuid())
  content   String
  userId    String
  parentId  String?
  eventId   String?
  venueId   String?
  postId    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  parent   Comment?  @relation("CommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies  Comment[] @relation("CommentReplies")
  event    Event?    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  venue    Venue?    @relation(fields: [venueId], references: [id], onDelete: Cascade)
  post     Post?     @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([parentId])
  @@index([eventId])
  @@index([venueId])
  @@index([postId])
}

model Media {
  id        String   @id @default(cuid())
  url       String
  alt       String?
  type      String   @default("IMAGE")
  order     Int      @default(0)
  venueId   String?
  eventId   String?
  postId    String?
  createdAt DateTime @default(now())

  venue Venue? @relation(fields: [venueId], references: [id], onDelete: Cascade)
  event Event? @relation(fields: [eventId], references: [id], onDelete: Cascade)
  post  Post?  @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@index([venueId])
  @@index([eventId])
  @@index([postId])
}

model OperatingHours {
  id        String   @id @default(cuid())
  venueId   String   @unique
  mon       String?
  tue       String?
  wed       String?
  thu       String?
  fri       String?
  sat       String?
  sun       String?
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  venue Venue @relation(fields: [venueId], references: [id], onDelete: Cascade)
}

model Review {
  id           String    @id @default(cuid())
  rating       Int
  title        String?
  content      String?
  ownerReply   String?
  ownerReplyAt DateTime?
  userId       String
  venueId      String?
  eventId      String?
  branchId     String?
  status        String    @default("APPROVED")
  flaggedReason String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  user   User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  venue  Venue?       @relation(fields: [venueId], references: [id], onDelete: Cascade)
  event  Event?       @relation(fields: [eventId], references: [id], onDelete: Cascade)
  branch Venue?       @relation("BranchReviews", fields: [branchId], references: [id], onDelete: SetNull)
  photos ReviewPhoto[]

  @@unique([userId, venueId])
  @@unique([userId, eventId])
  @@index([userId])
  @@index([venueId])
  @@index([eventId])
  @@index([rating])
  @@index([status])
  @@index([branchId])
}

model VenueClaim {
  id              String   @id @default(cuid())
  venueId         String
  userId          String
  status          String   @default("PENDING")   // PENDING | VERIFIED | APPROVED | REJECTED

  // Claimer info (snapshot del formulario)
  claimerName     String
  claimerEmail    String
  claimerPhone    String?
  claimerRole     String?                          // Cargo

  // Verification
  verificationCode String?
  codeExpiresAt    DateTime?
  attempts         Int      @default(0)
  verified         Boolean  @default(false)

  // Evidence
  evidenceUrl      String?                          // S3 URL
  evidenceName     String?                          // Nombre original del archivo

  // Trust score
  confidenceScore  Int      @default(0)             // 0-100

  // Legacy / admin
  proof           String?
  message         String?
  adminNotes      String?

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  venue Venue @relation(fields: [venueId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([venueId])
  @@index([userId])
  @@index([status])
  @@index([claimerEmail])
  @@index([verified])
}

model Promotion {
  id          String    @id @default(cuid())
  title       String
  description String
  image       String?
  discount    String?
  validFrom   DateTime
  validUntil  DateTime
  terms       String?
  status      String    @default("PENDING")
  featured    Boolean   @default(false)
  venueId     String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  venue Venue @relation(fields: [venueId], references: [id], onDelete: Cascade)

  @@index([venueId])
  @@index([status])
  @@index([validFrom])
  @@index([validUntil])
}

model Reservation {
  id           String   @id @default(cuid())
  venueId      String?
  eventId      String?
  userId       String
  date         DateTime
  time         String
  partySize    Int
  status       String   @default("PENDING")
  notes        String?
  cancelReason String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  venue Venue? @relation(fields: [venueId], references: [id], onDelete: Cascade)
  event Event? @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user  User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([venueId])
  @@index([eventId])
  @@index([userId])
  @@index([date])
  @@index([status])
}

model ReservationSettings {
  id                 String   @id @default(cuid())
  venueId            String   @unique
  acceptsReservations Boolean @default(true)
  maxPartySize       Int      @default(20)
  timeSlotDuration   Int      @default(60)
  openingTime        String   @default("09:00")
  closingTime        String   @default("22:00")
  autoConfirm        Boolean  @default(false)
  cancelBeforeHours  Int      @default(2)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  venue Venue @relation(fields: [venueId], references: [id], onDelete: Cascade)
}

model RecurrenceRule {
  id          String    @id @default(cuid())
  frequency   String
  interval    Int       @default(1)
  daysOfWeek  String?
  dayOfMonth  Int?
  startDate   DateTime
  endDate     DateTime?
  count       Int?
  eventId     String    @unique
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)
}

model Route {
  id          String   @id @default(cuid())
  title       String
  slug        String   @unique
  description String
  content     String?
  image       String?
  duration    String?
  difficulty  String?
  type        String
  status      String   @default("PENDING")
  featured    Boolean  @default(false)
  userId      String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  stops     RouteStop[]
  favorites Favorite[]
  collections CollectionItem[]

  @@index([status])
  @@index([type])
  @@index([userId])
}

model RouteStop {
  id        String   @id @default(cuid())
  routeId   String
  venueId   String?
  order     Int
  title     String
  notes     String?
  duration  String?

  route Route  @relation(fields: [routeId], references: [id], onDelete: Cascade)
  venue Venue? @relation(fields: [venueId], references: [id], onDelete: SetNull)

  @@unique([routeId, order])
  @@index([routeId])
}

model NewsletterSubscription {
  id         String   @id @default(cuid())
  email      String   @unique
  name       String?
  active     Boolean  @default(true)
  token      String   @unique
  confirmed  Boolean  @default(false)
  preferences String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([email])
  @@index([active])
}

model ReviewPhoto {
  id        String   @id @default(cuid())
  url       String
  reviewId  String
  order     Int      @default(0)
  createdAt DateTime @default(now())

  review Review @relation(fields: [reviewId], references: [id], onDelete: Cascade)

  @@index([reviewId])
}

model SpecialHours {
  id        String   @id @default(cuid())
  venueId   String
  date      DateTime
  openTime  String?
  closeTime String?
  isClosed  Boolean  @default(false)
  note      String?
  createdAt DateTime @default(now())

  venue Venue @relation(fields: [venueId], references: [id], onDelete: Cascade)

  @@unique([venueId, date])
  @@index([venueId])
}

model Question {
  id        String    @id @default(cuid())
  content   String
  userId    String
  venueId   String?
  eventId   String?
  answer    String?
  answerBy  String?
  answeredAt DateTime?
  status    String    @default("PENDING")
  createdAt DateTime  @default(now())

  user  User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  venue Venue? @relation(fields: [venueId], references: [id], onDelete: Cascade)
  event Event? @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@index([venueId])
  @@index([eventId])
  @@index([userId])
}

model Collection {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String?
  icon        String?
  isPublic    Boolean  @default(true)
  userId      String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user  User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  items CollectionItem[]

  @@index([userId])
}

model CollectionItem {
  id           String   @id @default(cuid())
  collectionId String
  venueId      String?
  eventId      String?
  postId       String?
  routeId      String?
  note         String?
  order        Int      @default(0)
  createdAt    DateTime @default(now())

  collection Collection @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  venue      Venue?     @relation(fields: [venueId], references: [id], onDelete: Cascade)
  event      Event?     @relation(fields: [eventId], references: [id], onDelete: Cascade)
  post       Post?      @relation(fields: [postId], references: [id], onDelete: Cascade)
  route      Route?     @relation(fields: [routeId], references: [id], onDelete: Cascade)

  @@unique([collectionId, venueId])
  @@unique([collectionId, eventId])
  @@unique([collectionId, postId])
  @@unique([collectionId, routeId])
  @@index([collectionId])
}

model MenuCategory {
  id        String     @id @default(cuid())
  name      String
  order     Int        @default(0)
  venueId   String
  createdAt DateTime   @default(now())

  venue Venue    @relation(fields: [venueId], references: [id], onDelete: Cascade)
  items MenuItem[]

  @@index([venueId])
}

model MenuItem {
  id             String   @id @default(cuid())
  name           String
  description    String?
  price          Float?
  image          String?
  order          Int      @default(0)
  isAvailable    Boolean  @default(true)
  isFeatured     Boolean  @default(false)
  allergens      String?  // JSON array de alergenos
  menuCategoryId String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  menuCategory MenuCategory @relation(fields: [menuCategoryId], references: [id], onDelete: Cascade)

  @@index([menuCategoryId])
}

model Product {
  id          String   @id @default(cuid())
  venueId     String
  name        String
  description String?
  price       Float?
  image       String?
  isAvailable Boolean  @default(true)
  isFeatured  Boolean  @default(false)
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  venue Venue @relation(fields: [venueId], references: [id], onDelete: Cascade)

  @@index([venueId])
}

model CheckIn {
  id        String   @id @default(cuid())
  userId    String
  venueId   String
  lat       Float
  lng       Float
  note      String?
  photoUrl  String?
  createdAt DateTime @default(now())

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  venue Venue @relation(fields: [venueId], references: [id], onDelete: Cascade)

  @@index([venueId])
  @@index([userId])
  @@index([createdAt])
}

model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model OsmImport {
  id              String   @id @default(cuid())
  city            String
  country         String
  categories      String
  radius          Int
  status          String   @default("PENDING")
  foundCount      Int      @default(0)
  importedCount   Int      @default(0)
  duplicateCount  Int      @default(0)
  errorCount      Int      @default(0)
  queryOverpass   String?
  errorMessage    String?
  createdBy       String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user  User          @relation(fields: [createdBy], references: [id], onDelete: Cascade)
  logs  OsmImportLog[]
  jobs  OsmSyncJob[]

  @@index([status])
  @@index([createdAt])
  @@index([createdBy])
}

model OsmImportLog {
  id        String   @id @default(cuid())
  importId  String
  message   String
  level     String   @default("INFO")
  metadata  String?
  createdAt DateTime @default(now())

  import OsmImport @relation(fields: [importId], references: [id], onDelete: Cascade)

  @@index([importId])
  @@index([level])
  @@index([createdAt])
}

model OsmSyncJob {
  id           String    @id @default(cuid())
  importId     String?
  type         String
  status       String    @default("PENDING")
  progress     Int       @default(0)
  total        Int       @default(0)
  processed    Int       @default(0)
  startedAt    DateTime?
  finishedAt   DateTime?
  errorMessage String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  import OsmImport? @relation(fields: [importId], references: [id], onDelete: SetNull)

  @@index([status])
  @@index([importId])
  @@index([createdAt])
}

model OsmConfig {
  id            String   @id @default(cuid())
  overpassUrl   String   @default("https://overpass-api.de/api/interpreter")
  timeout       Int      @default(30)
  maxResults    Int      @default(1000)
  delayBetween  Int      @default(1000)
  userAgent     String   @default("ViveLoja/1.0")
  syncFrequency String?
  syncEnabled   Boolean  @default(false)
  updatedAt     DateTime @updatedAt
}

model Message {
  id            String    @id @default(cuid())
  content       String?
  senderId      String
  receiverId    String
  venueId       String
  images        String[]  @default([])
  isRead        Boolean   @default(false)
  readAt        DateTime?
  isDeleted     Boolean   @default(false)
  deletedAt     DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  sender        User      @relation("SentMessages", fields: [senderId], references: [id], onDelete: Cascade)
  receiver      User      @relation("ReceivedMessages", fields: [receiverId], references: [id], onDelete: Cascade)
  venue         Venue     @relation(fields: [venueId], references: [id], onDelete: Cascade)

  @@index([senderId])
  @@index([receiverId])
  @@index([venueId])
  @@index([createdAt])
  @@index([isRead])
}

model QuickReply {
  id        String   @id @default(cuid())
  title     String
  content   String
  userId    String
  venueId   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  venue     Venue?   @relation(fields: [venueId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([venueId])
}

model BlockedUser {
  id            String   @id @default(cuid())
  venueId       String
  blockedUserId String
  blockedBy     String
  reason        String?
  createdAt     DateTime @default(now())

  venue         Venue    @relation(fields: [venueId], references: [id], onDelete: Cascade)
  blockedUser   User     @relation("BlockedUsers", fields: [blockedUserId], references: [id], onDelete: Cascade)
  blocker       User     @relation("Blockers", fields: [blockedBy], references: [id], onDelete: Cascade)

  @@unique([venueId, blockedUserId])
  @@index([venueId])
  @@index([blockedUserId])
}

model VenueBusinessHours {
  id         String   @id @default(cuid())
  venueId    String
  dayOfWeek  Int      // 0 = Domingo, 1 = Lunes, ..., 6 = Sabado
  openTime   String   // Formato "HH:MM"
  closeTime  String   // Formato "HH:MM"
  isClosed   Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  venue Venue @relation(fields: [venueId], references: [id], onDelete: Cascade)

  @@index([venueId])
  @@index([venueId, dayOfWeek])
}

model VenueService {
  id          String   @id @default(cuid())
  venueId     String
  name        String
  description String?
  icon        String?
  isCustom    Boolean  @default(false)
  isActive    Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  venue Venue @relation(fields: [venueId], references: [id], onDelete: Cascade)

  @@unique([venueId, name])
  @@index([venueId])
}

model GoogleImportJob {
  id               String   @id @default(cuid())
  status           String   @default("PENDING")
  country          String
  province         String
  city             String
  categories       String
  radius           Int
  totalRecords     Int      @default(0)
  processedRecords Int      @default(0)
  importedRecords  Int      @default(0)
  duplicateRecords Int      @default(0)
  errorRecords     Int      @default(0)
  startedAt        DateTime?
  finishedAt       DateTime?
  createdBy        String
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  pausedAt         DateTime?
  currentBatchIndex Int     @default(0)
  batchData        String?
  jobType          String   @default("IMPORT")
  duplicateAction  String   @default("skip")
  delayMs          Int      @default(0)

  user User             @relation(fields: [createdBy], references: [id], onDelete: Cascade)
  logs GoogleImportLog[]

  @@index([status])
  @@index([createdAt])
  @@index([createdBy])
  @@index([jobType])
}

model GoogleImportLog {
  id        String   @id @default(cuid())
  jobId     String
  level     String   @default("INFO")
  message   String
  metadata  String?
  createdAt DateTime @default(now())

  job GoogleImportJob @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@index([jobId])
  @@index([level])
  @@index([createdAt])
}

model SearchConsoleSnapshot {
  id               String   @id @default(cuid())
  date             DateTime @unique
  totalClicks      Int
  totalImpressions Float
  averageCtr       Float
  averagePosition  Float
  createdAt        DateTime @default(now())

  @@index([date])
}

model SearchConsoleKeyword {
  id          String   @id @default(cuid())
  date        DateTime
  query       String
  clicks      Int
  impressions Float
  ctr         Float
  position    Float
  createdAt   DateTime @default(now())

  @@unique([date, query])
  @@index([date])
  @@index([query])
  @@index([impressions])
  @@index([ctr])
}

model SearchConsolePage {
  id          String   @id @default(cuid())
  date        DateTime
  page        String
  clicks      Int
  impressions Float
  ctr         Float
  position    Float
  createdAt   DateTime @default(now())

  @@unique([date, page])
  @@index([date])
  @@index([page])
  @@index([impressions])
  @@index([ctr])
}

model SearchConsoleOpportunity {
  id              String   @id @default(cuid())
  query           String
  page            String?
  opportunityType String
  score           Float
  impressions     Float
  clicks          Int
  ctr             Float
  position        Float
  recommendation  String
  suggestedUrl    String?
  suggestedTitle  String?
  status          String   @default("OPEN")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([opportunityType])
  @@index([status])
  @@index([score])
  @@index([query])
}

